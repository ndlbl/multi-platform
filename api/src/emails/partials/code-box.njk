{# Shared OTP code display — used by both register and login emails #}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td align="center" style="padding: 8px 0 16px;">
      <div style="display: inline-block; background-color: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 10px; padding: 16px 28px;">
        <span style="font-family: 'Courier New', Courier, monospace; font-size: 32px; font-weight: bold; letter-spacing: 8px; color: #4f46e5;">
          {{ code }}
        </span>
      </div>
    </td>
  </tr>
</table>
<p style="margin: 0; font-size: 13px; color: #94a3b8; text-align: center;">
  This code expires in {{ expiryMinutes }} minutes.
</p>
