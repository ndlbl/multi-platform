{
  "name": "e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Cypress end-to-end tests for the Angular, React, and Vue frontends against the live API + MongoDB.",
  "scripts": {
    "cy:open": "cypress open",
    "e2e:angular": "cypress run --config baseUrl=http://localhost:4200 --spec 'cypress/e2e/angular/**/*.cy.ts'",
    "e2e:react": "cypress run --config baseUrl=http://localhost:5173 --spec 'cypress/e2e/react/**/*.cy.ts'",
    "e2e:vue": "cypress run --config baseUrl=http://localhost:5174 --spec 'cypress/e2e/vue/**/*.cy.ts'",
    "e2e:all": "concurrently -n NG,RX,VU -c cyan,magenta,yellow \"npm run e2e:angular\" \"npm run e2e:react\" \"npm run e2e:vue\""
  },
  "devDependencies": {
    "bcryptjs": "^3.0.2",
    "concurrently": "^10.0.3",
    "cypress": "^14.5.4",
    "dotenv": "^16.4.7",
    "mongodb": "^6.12.0",
    "typescript": "~5.7.2"
  }
}
